  "approachKiss.Abigail.6": "Ai! Você me pegou em cheio.",
  "approachKiss.Abigail.7": "Nossa, beijo com dano crítico.",
  "approachKiss.Abigail.8": "Ei! Assim você me faz errar o passo.",
  "approachKiss.Abigail.9": "Nossa... que colisão mais fofa.",
  "approachKiss.Abigail.10": "Você passa voando e ainda faz isso?",
  "approachKiss.Abigail.11": "Você me pegou desprevenida!",
  "approachKiss.Abigail.12": "Eu não estava pronta, mas gostei.",
  "approachKiss.Abigail.13": "Ei! Eu nem tive chance de revidar.",
  "approachKiss.Abigail.14": "Que colisão perfeitamente calculada.",
  "approachKiss.Abigail.15": "Que jeito agressivamente fofo de dizer oi.",
  "approachKiss.Abigail.16": "Ei, vai com calma! Ou não.",
  "approachKiss.Abigail.17": "Uau— ataque surpresa!",
  "approachKiss.Abigail.18": "Um beijo surpresa? Adorei a tática.",
  "approachKiss.Abigail.19": "Haha! Quero revanche desse beijo.",
  "approachKiss.Abigail.20": "Beijo relâmpago desbloqueado.",

  //EMILY

  "approachKiss.Emily.1": "Oh! Você apareceu feito mágica.",
  "approachKiss.Emily.2": "Ei! Quase me fez girar agora.",
  "approachKiss.Emily.3": "Nossa! Que energia foi essa?",
  "approachKiss.Emily.4": "Opa! Um beijo com impulso.",
  "approachKiss.Emily.5": "Ah! Você chegou brilhando hoje.",
  "approachKiss.Emily.6": "Oh! Que energia linda!",
  "approachKiss.Emily.7": "Que jeito intenso de me cumprimentar.",
  "approachKiss.Emily.8": "Que colisão mais fofa!",
  "approachKiss.Emily.9": "Esse beijo iluminou meu dia.",
  "approachKiss.Emily.10": "Assim você bagunça minha aura toda.",
  "approachKiss.Emily.11": "Meu coração quase saiu dançando.",
  "approachKiss.Emily.12": "Você me pegou bem distraída.",
  "approachKiss.Emily.13": "Ai! Quase me fez perder o equilíbrio.",
  "approachKiss.Emily.14": "Que jeito mágico de dizer oi!",
  "approachKiss.Emily.15": "Isso foi caótico e adorável.",
