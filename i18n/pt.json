  "approachKiss.Emily.17": "Que surpresa maravilhosa!",
  "approachKiss.Emily.18": "Esse beijo pareceu destino.",
  "approachKiss.Emily.19": "Que impacto mais doce.",
  "approachKiss.Emily.20": "Minha alma deu uma pirueta.",

  //HALEY

  "approachKiss.Haley.1": "Ai! Cuidado com o meu cabelo.",
